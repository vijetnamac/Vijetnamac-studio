// ── PARALLAX GALLERY ──
const pgItems = document.querySelectorAll('.pg-item');

function updateParallax() {
  const vh = window.innerHeight;
  pgItems.forEach(item => {
    const rect = item.getBoundingClientRect();
    if (rect.bottom < -300 || rect.top > vh + 300) return;
    const img = item.querySelector('img');
    if (!img) return;
    const progress = 1 - (rect.top + rect.height) / (rect.height + vh);
    const clamped = Math.min(1, Math.max(0, progress));
    const shift = -20 + clamped * 40;
    img.style.transform = `translateY(${shift}%)`;
  });
  requestAnimationFrame(updateParallax);
}
requestAnimationFrame(updateParallax);

// ── SCROLL REVEAL ──
const revealEls = document.querySelectorAll(".reveal");

function reveal() {
  revealEls.forEach(el => {
    if (el.getBoundingClientRect().top < window.innerHeight - 80) {
      el.classList.add("active");
    }
  });
}

window.addEventListener("scroll", reveal, { passive: true });
