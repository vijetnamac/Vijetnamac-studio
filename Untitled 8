<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vijetnamac Studio</title>
<link rel="icon" type="image/png" href="data:image/png;base64,">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:wght@300;400;500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
:root {
  --gold: #d4af37;
  --gold-light: #ffd700;
  --bg: #080808;
  --surface: #111111;
  --border: #1e1e1e;
  --text-muted: #666;
}

*, *::before, *::after { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  background: var(--bg);
  color: #fff;
  font-family: 'Jost', sans-serif;
  overflow-x: hidden;
}

/* ── NAVBAR ── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 40px;
  background: linear-gradient(to bottom, rgba(8,8,8,0.92), transparent);
  backdrop-filter: blur(4px);
}

.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  letter-spacing: 3px;
  color: var(--gold);
  text-transform: uppercase;
  text-decoration: none;
}

.nav-links {
  display: flex;
  gap: 32px;
  list-style: none;
  margin: 0; padding: 0;
  align-items: center;
}

.nav-links a {
  color: #aaa;
  text-decoration: none;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  transition: color 0.3s;
}

.nav-links a:hover { color: var(--gold); }

.nav-lang {
  display: flex;
  gap: 4px;
  margin-left: 8px;
  border-left: 1px solid var(--border);
  padding-left: 20px;
}

.lang-btn {
  background: none;
  border: 1px solid transparent;
  color: var(--text-muted);
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 5px 10px;
  cursor: pointer;
  transition: all 0.3s ease;
  border-radius: 2px;
}

.lang-btn.active { border-color: var(--gold); color: var(--gold); }
.lang-btn:hover { color: var(--gold); }

/* ── HERO ── */
.hero {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: url('https://images.unsplash.com/photo-1519741497674-611481863552') center/cover no-repeat;
  background-attachment: fixed;
  position: relative;
}

.hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(8,8,8,0.3) 0%, rgba(8,8,8,0.5) 60%, rgba(8,8,8,1) 100%);
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-eyebrow {
  font-size: 11px;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 1s ease 0.3s forwards;
}

.hero h1 {
  font-size: clamp(36px, 6vw, 72px);
  font-family: 'Playfair Display', serif;
  font-weight: 400;
  background: linear-gradient(135deg, #fff 30%, var(--gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 0 0 16px;
  opacity: 0;
  animation: fadeUp 1s ease 0.6s forwards;
  line-height: 1.1;
}

.hero p {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-style: italic;
  color: #ccc;
  margin-bottom: 40px;
  opacity: 0;
  animation: fadeUp 1s ease 0.9s forwards;
}

.hero-divider {
  width: 60px;
  height: 1px;
  background: var(--gold);
  margin: 0 auto 40px;
  opacity: 0;
  animation: fadeUp 1s ease 0.75s forwards;
}

/* ── BUTTON ── */
.btn {
  display: inline-block;
  padding: 14px 36px;
  background: transparent;
  border: 1px solid var(--gold);
  border-radius: 0;
  color: var(--gold);
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.4s ease;
  text-decoration: none;
  opacity: 0;
  animation: fadeUp 1s ease 1.1s forwards;
}

.btn:hover {
  background: var(--gold);
  color: #000;
  transform: translateY(-2px);
  box-shadow: 0 10px 40px rgba(212,175,55,0.3);
}

/* ── SCROLL REVEAL ── */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.9s ease, transform 0.9s ease;
}

.reveal.active {
  opacity: 1;
  transform: translateY(0);
}

/* ── SECTION TITLE ── */
.section-label {
  font-size: 10px;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
}

h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 400;
  margin: 0 0 40px;
}

/* ── PARALLAX GALLERY ── */
.portfolio-section {
  padding: 100px 0 0;
}

.portfolio-header {
  padding: 0 40px 60px;
  max-width: 1200px;
  margin: auto;
}

.parallax-gallery {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 6px;
  padding: 0 6px 6px;
}

.pg-item {
  position: relative;
  overflow: hidden;
  border-radius: 3px;
  cursor: pointer;
  background: #111;
}

/* height variants */
.pg-item         { height: 340px; }
.pg-item.pg-tall { height: 500px; }
.pg-item.pg-wide { grid-column: span 2; height: 360px; }
.pg-item.pg-full { grid-column: span 3; height: 480px; }

.pg-item img {
  position: absolute;
  top: -20%;
  left: 0;
  width: 100%;
  height: 140%;
  object-fit: cover;
  will-change: transform;
  transition: transform 0.05s linear;
}

.pg-item::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 55%);
  opacity: 0;
  transition: opacity 0.4s ease;
  z-index: 1;
}

.pg-item:hover::after { opacity: 1; }

.pg-item:hover img { transform: scale(1.04) !important; }

/* ── OLD LANG SWITCHER IN FOOTER (remove margin) ── */
.lang-switcher { display: none; }

@media (max-width: 768px) {
  .portfolio-header { padding: 0 20px 40px; }
  .parallax-gallery { grid-template-columns: 1fr 1fr; gap: 4px; }
  .pg-item.pg-full { grid-column: span 2; }
  .pg-item.pg-wide { grid-column: span 2; }
  .pg-item, .pg-item.pg-tall { height: 200px; }
  .pg-item.pg-full { height: 260px; }
  .pg-item img { transition: none; }
}

/* ── ABOUT ── */
.about-cinematic {
  position: relative;
  height: 80vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  overflow: hidden;
}

.about-cinematic::before {
  content: "";
  position: absolute;
  inset: 0;
  background: url('https://i.imgur.com/iC5sJWU.png') center/cover no-repeat;
  animation: cinematicZoom 12s ease-in-out infinite alternate;
  z-index: 0;
}

.about-cinematic::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(4px);
  z-index: 1;
}

.about-content {
  position: relative;
  z-index: 2;
  max-width: 580px;
  padding: 0 20px;
}

.about-content h2 { margin-bottom: 20px; }

.about-content p {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-style: italic;
  color: #ccc;
  line-height: 1.8;
}

/* ── PACKAGES ── */
.packages-cinematic {
  position: relative;
  padding: 120px 40px;
  overflow: hidden;
}

.packages-cinematic::before {
  content: "";
  position: absolute;
  inset: 0;
  background: url('https://i.imgur.com/koPssAn.jpeg') center/cover;
  animation: cinematicZoom 15s ease-in-out infinite alternate;
  z-index: 0;
}

.packages-cinematic::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.82);
  backdrop-filter: blur(5px);
  z-index: 1;
}

.packages-inner {
  position: relative;
  z-index: 2;
  max-width: 700px;
  margin: auto;
}

.packages-inner h2 { text-align: center; }
.packages-inner .section-label { text-align: center; }

.package {
  border: 1px solid var(--border);
  padding: 28px 32px;
  margin: 12px 0;
  border-radius: 2px;
  cursor: pointer;
  transition: all 0.4s ease;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255,255,255,0.02);
}

.package-name {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  font-weight: 400;
}

.package-sub {
  font-size: 12px;
  color: var(--text-muted);
  letter-spacing: 1px;
  margin-top: 4px;
  font-family: 'Jost', sans-serif;
}

.package-arrow {
  color: var(--gold);
  font-size: 18px;
  transition: transform 0.3s;
}

.package:hover {
  border-color: var(--gold);
  background: rgba(212,175,55,0.05);
  transform: translateX(6px);
}

.package:hover .package-arrow { transform: translateX(5px); }

/* ── SOCIAL ── */
.social-section {
  text-align: center;
  padding: 100px 20px;
}

.social-icons {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 40px;
}

.social-icons a {
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--surface);
  border: 1px solid var(--border);
  font-size: 22px;
  color: #888;
  text-decoration: none;
  transition: all 0.4s ease;
}

.social-icons a:hover {
  transform: translateY(-6px);
  color: #fff;
}

.social-icons a:nth-child(1):hover {
  background: linear-gradient(45deg,#feda75,#fa7e1e,#d62976,#962fbf,#4f5bd5);
  border-color: transparent;
}

.social-icons a:nth-child(2):hover {
  background: #000;
  border-color: #333;
  box-shadow: 0 0 20px rgba(0,242,234,0.3), 0 0 40px rgba(255,0,80,0.2);
}

.social-icons a:nth-child(3):hover {
  background: #111;
  border-color: #444;
}

/* ── BOOKING SECTION ── */
.booking-section {
  padding: 100px 40px;
  max-width: 480px;
  margin: auto;
  text-align: center;
}

.booking-section h2 { margin-bottom: 40px; }

.contact-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.contact-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 28px 16px;
  cursor: pointer;
  transition: all 0.4s ease;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

.contact-card:nth-child(1):hover {
  border-color: #e1306c;
  background: rgba(225,48,108,0.07);
  transform: translateY(-4px);
}

.contact-card:nth-child(2):hover {
  border-color: #7e5bef;
  background: rgba(126,91,239,0.07);
  transform: translateY(-4px);
}

.contact-card-icon {
  font-size: 26px;
  transition: transform 0.3s;
}

.contact-card:nth-child(1) .contact-card-icon { color: #e1306c; }
.contact-card:nth-child(2) .contact-card-icon { color: #7e5bef; }

.contact-card:hover .contact-card-icon { transform: scale(1.15); }

.contact-card-label {
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--text-muted);
}

/* ── CONTACT POPUP (per platform) ── */
.contact-popup {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(14px);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 998;
}

.contact-popup.open { display: flex; }

.contact-popup-content {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 44px 36px;
  max-width: 360px;
  width: 92%;
  text-align: center;
  position: relative;
  animation: popupFade 0.4s ease;
}

.contact-popup-content h2 {
  font-family: 'Playfair Display', serif;
  font-size: 24px;
  font-weight: 400;
  margin-bottom: 6px;
}

.contact-popup-sub {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  color: var(--text-muted);
  font-size: 15px;
  margin-bottom: 28px;
}

.contact-popup-icon {
  font-size: 40px;
  margin-bottom: 16px;
  display: block;
}

.contact-popup-detail {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  color: #fff;
  margin-bottom: 28px;
  letter-spacing: 1px;
}

.contact-popup-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 13px 28px;
  border-radius: 2px;
  text-decoration: none;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  transition: all 0.3s ease;
  border: 1px solid;
}

.contact-popup-btn.instagram {
  color: #e1306c;
  border-color: #e1306c;
}
.contact-popup-btn.instagram:hover {
  background: #e1306c;
  color: #fff;
}

.contact-popup-btn.viber {
  color: #7e5bef;
  border-color: #7e5bef;
}
.contact-popup-btn.viber:hover {
  background: #7e5bef;
  color: #fff;
}

@media (max-width: 768px) {
  .booking-section { padding: 60px 20px; }
}

/* ── POPUP ── */
.popup {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.8);
  backdrop-filter: blur(12px);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.popup.open { display: flex; }

.popup-content {
  background: var(--surface);
  padding: 48px 40px;
  border-radius: 2px;
  max-width: 420px;
  width: 90%;
  text-align: center;
  border: 1px solid var(--border);
  animation: popupFade 0.4s ease;
  position: relative;
}

.popup-content h2 {
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  font-weight: 400;
  margin-bottom: 24px;
}

.popup-features {
  list-style: none;
  padding: 0; margin: 0 0 32px;
  text-align: left;
}

.popup-features li {
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  color: #ccc;
  font-size: 14px;
  display: flex;
  gap: 12px;
  align-items: center;
}

.popup-features li::before {
  content: "—";
  color: var(--gold);
  flex-shrink: 0;
}

.close-btn {
  position: absolute;
  top: 16px; right: 20px;
  font-size: 22px;
  cursor: pointer;
  color: var(--text-muted);
  background: none;
  border: none;
  transition: color 0.3s;
  line-height: 1;
}

.close-btn:hover { color: #fff; }

/* ── FOOTER ── */
footer {
  text-align: center;
  padding: 60px 40px;
  color: var(--text-muted);
  border-top: 1px solid var(--border);
  font-size: 12px;
  letter-spacing: 2px;
}

footer .footer-logo {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  color: var(--gold);
  margin-bottom: 16px;
  display: block;
}

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes cinematicZoom {
  from { transform: scale(1); }
  to   { transform: scale(1.12); }
}

@keyframes popupFade {
  from { opacity: 0; transform: scale(0.92) translateY(10px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  nav { padding: 16px 20px; }
  .nav-links { display: none; }
  .portfolio-section { padding: 60px 16px; }
  .grid { grid-template-columns: 1fr 1fr; }
  .grid-item:nth-child(4n+1) { grid-column: span 2; aspect-ratio: 16/9; }
  .packages-cinematic { padding: 80px 20px; }
  .booking-section { padding: 60px 20px; }
}
</style>

</head>

